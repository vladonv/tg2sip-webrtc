diff --git a/tgcalls/third_party/webrtc/CMakeLists.txt b/tgcalls/third_party/webrtc/CMakeLists.txt
index e7684cc0..91178b09 100644
--- a/tgcalls/third_party/webrtc/CMakeLists.txt
+++ b/tgcalls/third_party/webrtc/CMakeLists.txt
@@ -2324,6 +2324,16 @@ if (WIN32)
 else()
 endif()
 
+# tg2sip integration: audio-only build, drop the FFmpeg-backed H264
+# decoder/encoder. WEBRTC_USE_H264 is undefined (cmake/libwebrtcbuild.cmake),
+# so h264.cc's own #ifdef fallback (mirrors the AV1 "_absent" stubs) is used
+# instead. Needed because this file doesn't compile against FFmpeg 7.x
+# (AVFrame/AVCodecContext::reordered_opaque was removed upstream).
+remove_target_sources(tg_owt ${webrtc_loc}
+    modules/video_coding/codecs/h264/h264_decoder_impl.cc
+    modules/video_coding/codecs/h264/h264_encoder_impl.cc
+)
+
 set(platform_export)
 if (NOT WIN32 AND NOT APPLE AND NOT LIBEVENT_FOUND)
     set(platform_export
diff --git a/tgcalls/third_party/webrtc/cmake/libwebrtcbuild.cmake b/tgcalls/third_party/webrtc/cmake/libwebrtcbuild.cmake
index 99b2395b..6719679b 100644
--- a/tgcalls/third_party/webrtc/cmake/libwebrtcbuild.cmake
+++ b/tgcalls/third_party/webrtc/cmake/libwebrtcbuild.cmake
@@ -17,7 +17,6 @@ INTERFACE
     WEBRTC_OPUS_VARIABLE_COMPLEXITY=0
     WEBRTC_OPUS_SUPPORT_120MS_PTIME=1
     WEBRTC_INCLUDE_INTERNAL_AUDIO_DEVICE
-    WEBRTC_USE_H264
     WEBRTC_LIBRARY_IMPL
     WEBRTC_NON_STATIC_TRACE_EVENT_HANDLERS=1
     NO_MAIN_THREAD_WRAPPING
